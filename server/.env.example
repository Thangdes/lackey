# Server application environment (example)
# Copy this file to .env and fill with your real secrets (do NOT commit)

# Core
NODE_ENV=production
PORT=8000
REQUEST_TIMEOUT_MS=30000

# Database (inside Docker network)
MONGODB_URI="mongodb://mongoadmin:mongosecret@mongo:27017/cvf?authSource=admin"

# Cache
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_TTL_SECONDS=86400

# Auth
JWT_SECRET="change_me"
JWT_ACCESS_EXPIRES="1d"
JWT_REFRESH_EXPIRES="7d"
BCRYPT_ROUNDS=10
MAX_SESSIONS_PER_USER=5
AUTH_COOKIE_DOMAIN=.lackey.click
CORS_ORIGINS=https://lackey.click,https://www.lackey.click

# Cloudinary
CLOUDINARY_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Email
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your_email@example.com"
EMAIL_PASS="your_app_password"
EMAIL_FROM="\"Lackey\" <no-reply@lackey.vn>"

# Telegram (optional)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_WEBHOOK_URL=""

# Commerce / Payments
ORDER_IDEMPOTENCY_MINUTES=10
UNPAID_CANCEL_GRACE_HOURS=48
