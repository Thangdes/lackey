// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SALE
  ADMIN
  SUPPLIER
}

enum OrderStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  PREPARING_SHIPMENT
  SHIPPED
  COMPLETED
  CANCELED
}

enum PaymentMethod {
  VIETQR
  COD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentEventType {
  CREATED
  CONFIRMED
  FAILED
  CANCELED
  RECONCILED
}


enum ContentType {
  BANNER
  TESTIMONIAL
  GALLERY
}

model Customer {
  id        String    @id @default(uuid())
  email     String    @unique @db.VarChar(100)
  fullName  String?   @map("full_name") @db.VarChar(255)
  phone     String?   @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  user      User?
  addresses Address[]
  cartItems CartItem[]
  orders    Order[]
  ratings   Rating[]
  @@map("customers")
}

model User {
  id         String    @id @default(uuid())
  customerId String?    @unique @map("customer_id")
  supplierId String?   @map("supplier_id")
  isActive   Boolean   @default(true) @map("is_active")
  username   String    @unique @db.VarChar(50)
  password   String    @db.VarChar(255)
  avatar     String?   @db.VarChar(255)
  role       UserRole  @default(CUSTOMER)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  tokens     Token[]
  posts      Post[]
  @@map("users")
}

model Token {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("tokens")
}

model Address {
  id             String   @id @default(uuid())
  customerId     String   @map("customer_id")
  recipientName  String   @map("recipient_name") @db.VarChar(255)
  phoneNumber    String   @map("phone_number") @db.VarChar(20)
  street         String   @db.VarChar(255)
  ward           String   @db.VarChar(100)
  district       String   @db.VarChar(100)
  city           String   @db.VarChar(100)
  fullAddress    String?  @map("full_address") @db.Text
  isDefault      Boolean  @default(false) @map("is_default")
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders         Order[]
  @@map("addresses")
}

model Supplier {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(255)
  contactName String?   @map("contact_name") @db.VarChar(255)
  email       String    @unique @db.VarChar(100)
  phone       String?   @db.VarChar(20)
  address     String?   @db.Text
  description String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  products    Product[]
  users       User[]

  @@map("suppliers")
}

model CartItem {
  id               String   @id @default(uuid())
  customerId       String?  @map("customer_id")
  guestCartId      String?  @map("guest_cart_id")
  productVariantId String   @map("product_variant_id")
  quantity         Int      @default(1)
  createdAt        DateTime @default(now()) @map("created_at")
  customer         Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  @@unique([customerId, productVariantId])
  @@index([customerId])
  @@index([guestCartId])
  @@map("cart_items")
}

model Order {
  id                String      @id @default(uuid())
  customerId        String      @map("customer_id")
  shippingAddressId String      @map("shipping_address_id")
  orderCode         String      @unique @map("order_code") @db.VarChar(20)
  status            OrderStatus @default(PENDING_CONFIRMATION)
  subtotalAmount    Decimal     @map("subtotal_amount") @db.Decimal(12, 2)
  shippingFee       Decimal     @default(0) @map("shipping_fee") @db.Decimal(12, 2)
  totalAmount       Decimal     @map("total_amount") @db.Decimal(12, 2)
  notes             String?     @db.Text
  createdAt         DateTime    @default(now()) @map("created_at")
  confirmedAt       DateTime?   @map("confirmed_at")
  shippedAt         DateTime?   @map("shipped_at")
  completedAt       DateTime?   @map("completed_at")
  canceledAt        DateTime?   @map("canceled_at")
  customer          Customer    @relation(fields: [customerId], references: [id])
  shippingAddress   Address     @relation(fields: [shippingAddressId], references: [id])
  orderItems        OrderItem[]
  payments          Payment[]
  paymentEvents     PaymentEvent[]
  ratings           Rating[]
  invoice           Invoice?
  deliveryCode      String?      @unique @map("delivery_code")
  discountId        String?      @map("discount_id")
  discountAmount    Decimal      @default(0) @map("discount_amount") @db.Decimal(12, 2)
  discount          Discount?    @relation(fields: [discountId], references: [id])
  @@map("orders")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  products    Product[]
  @@map("categories")
  thumbnailUrl String?        @map("thumbnail_url") @db.VarChar(255)
}

model Product {
  id           String         @id @default(uuid())
  categoryId   String         @map("category_id")
  supplierId   String         @map("supplier_id")
  name         String         @db.VarChar(255)
  slug         String         @unique @db.VarChar(255)
  description  String?        @db.Text
  thumbnailUrl String?        @map("thumbnail_url") @db.VarChar(255)
  isActive     Boolean        @default(true) @map("is_active")
  initialBuyCount Int @default(0) @map("initial_buy_count")
  buyCount     Int            @default(0) @map("buy_count") 
  ratingAvg    Float          @default(0) @map("rating_avg") 
  ratingCount  Int            @default(0) @map("rating_count") 
  category     Category       @relation(fields: [categoryId], references: [id])
  supplier     Supplier       @relation(fields: [supplierId], references: [id])
  variants     ProductVariant[]
  ratings      Rating[]
  images       String[]       @default([])  
  @@index([supplierId])     
  @@map("products")
}

model ProductVariant {
  id            String       @id @default(uuid())
  productId     String       @map("product_id")
  name          String       @db.VarChar(100)
  sku           String       @unique @db.VarChar(50)
  price         Decimal      @db.Decimal(12, 2)
  discountPrice Decimal?     @map("discount_price") @db.Decimal(12, 2)
  stockQuantity Int          @default(0) @map("stock_quantity")
  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  ratings       Rating[]
  @@map("product_variants")
}

model Rating {
  id               String   @id @default(uuid())
  customerId       String   @map("customer_id")
  productId        String   @map("product_id")
  productVariantId String   @map("product_variant_id")
  orderId          String   @map("order_id")
  ratingValue      Int      @map("rating_value")
  comment          String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  customer         Customer       @relation(fields: [customerId], references: [id])
  product          Product        @relation(fields: [productId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  order            Order          @relation(fields: [orderId], references: [id])
  
  @@unique([customerId, productVariantId, orderId])
  @@map("ratings")
}

model OrderItem {
  id                String         @id @default(uuid())
  orderId           String         @map("order_id")
  productVariantId  String         @map("product_variant_id")
  quantity          Int
  priceAtPurchase   Decimal        @map("price_at_purchase") @db.Decimal(12, 2)
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant    ProductVariant @relation(fields: [productVariantId], references: [id])
  autoRated         Boolean        @default(false) @map("auto_rated")
  @@map("order_items")
}

model Payment {
  id              String        @id @default(uuid())
  orderId         String        @map("order_id")
  method          PaymentMethod
  amount          Decimal       @db.Decimal(12, 2)
  status          PaymentStatus @default(PENDING)
  transactionCode String?       @map("transaction_code") @db.VarChar(255)
  paidAt          DateTime?     @map("paid_at")
  confirmedBy     String?       @map("confirmed_by") @db.VarChar(100)
  confirmedAt     DateTime?     @map("confirmed_at")
  externalTxnId   String?       @map("external_txn_id") @db.VarChar(255)
  order           Order         @relation(fields: [orderId], references: [id])
  invoice         Invoice?
  events          PaymentEvent[]
  @@map("payments")
  @@index([orderId])
  @@index([status])
}

model PaymentEvent {
  id        String            @id @default(uuid())
  paymentId String            @map("payment_id")
  orderId   String            @map("order_id")
  type      PaymentEventType
  metadata  Json?
  createdAt DateTime          @default(now()) @map("created_at")
  payment   Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@map("payment_events")
  @@index([paymentId])
  @@index([orderId])
}

model Invoice {
  id            String   @id @default(uuid())
  orderId       String   @unique @map("order_id")
  paymentId     String   @unique @map("payment_id")
  invoiceNumber String   @unique @map("invoice_number") @db.VarChar(50)
  pdfUrl        String?  @map("pdf_url") @db.VarChar(255)
  issuedAt      DateTime @default(now()) @map("issued_at")
  order         Order    @relation(fields: [orderId], references: [id])
  payment       Payment  @relation(fields: [paymentId], references: [id])
  @@map("invoices")
}

model CmsPage {
  id          String   @id @default(uuid())
  slug        String   @unique @db.VarChar(255)
  title       String   @db.VarChar(255)
  contentHtml String?  @map("content_html") @db.Text
  isPublished Boolean  @default(false) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("cms_pages")
}

enum DiscountType {
  FIXED_AMOUNT
  PERCENTAGE
}

model Discount {
  id          String       @id @default(uuid())
  code        String       @unique @db.VarChar(50)
  description String?      @db.Text
  type        DiscountType
  value       Decimal      @db.Decimal(12, 2)
  isActive    Boolean      @default(true) @map("is_active")
  startDate   DateTime     @map("start_date")
  endDate     DateTime?    @map("end_date")
  minAmount   Decimal?     @map("min_amount") @db.Decimal(12, 2)
  usageLimit  Int?         @map("usage_limit")
  usedCount   Int          @default(0) @map("used_count")
  perUserLimit Int?        @map("per_user_limit")
  maxDiscountAmount Decimal? @map("max_discount_amount") @db.Decimal(12, 2)
  stackable   Boolean      @default(false)
  orders      Order[]
  @@map("discounts")
}

model Post {
  id           String    @id @default(uuid())
  title        String    @db.VarChar(255)        
  slug         String    @unique @db.VarChar(255)  
  content      String    @db.Text                
  excerpt      String?   @db.Text                
  thumbnailUrl String?   @map("thumbnail_url") @db.VarChar(255) 
  isPublished  Boolean   @default(false) @map("is_published") 
  authorId     String    @map("author_id")        
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  metaTitle       String?   @map("meta_title") @db.VarChar(70)
  metaDescription String?   @map("meta_description") @db.VarChar(160)
  author       User      @relation(fields: [authorId], references: [id])

  @@map("posts")
}


model SiteContent {
  id           String      @id @default(uuid())
  type         ContentType 
  title        String      @db.VarChar(255)
  content      String?     @db.Text
  thumbnailUrl String?     @map("thumbnail_url") @db.VarChar(255)
  linkUrl      String?     @map("link_url") @db.VarChar(255)
  authorName   String?     @map("author_name") @db.VarChar(100)
  authorTitle  String?     @map("author_title") @db.VarChar(100)
  displayOrder Int         @default(0) @map("display_order")
  isPublished  Boolean     @default(false) @map("is_published")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  @@map("site_content")
}