# Infrastructure environment for Docker Compose (example)
# Copy to .env for local infra only. Do NOT put application secrets here.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cvf

# pgAdmin
PGADMIN_DEFAULT_EMAIL=you@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

# Networking
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/cvf?schema=public"
REDIS_HOST=redis
REDIS_PORT=6379

# Optional: Ngrok (not recommended to commit real token)
NGROK_AUTHTOKEN=

# Optional: App port for reference
PORT=8000

# Seed & bootstrap controls (server app)
# Run seed on container start (only for first run); set to false in prod
SEED_ON_START=false
# Seed sample data (dev/local only); keep false in prod
SEED_SAMPLE_DATA=false
# Destructive reset (NEVER enable in prod)
ALLOW_DESTRUCTIVE_SEED=false
# Admin bootstrap credentials (used if admin user missing)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@cvfood.com
ADMIN_PASSWORD=Admin@123
